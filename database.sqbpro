CREATE TABLE annee_universitaire (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    annee TEXT NOT NULL UNIQUE,
    date_debut DATE NOT NULL,
    date_fin DATE NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CHECK (date_fin &gt; date_debut)
);
-- Table: Programme
CREATE TABLE programme (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    code TEXT NOT NULL UNIQUE,
    titre TEXT NOT NULL,
    doctorat INTEGER DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Table: Etudiant (with search optimization fields)
CREATE TABLE etudiant (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nom TEXT NOT NULL,
    prenom TEXT NOT NULL,
    matricule TEXT NOT NULL UNIQUE,
    sexe TEXT,
    date_naissance DATE,
    lieu_naissance TEXT,
    
    -- Search optimization fields
    nom_soundex TEXT,
    prenom_soundex TEXT,
    nom_metaphone TEXT,
    prenom_metaphone TEXT,
    nom_trigram TEXT,
    prenom_trigram TEXT,
    matricule_normalise TEXT,  -- Normalized matricule for fuzzy matching
    matricule_prefixes TEXT,    -- For prefix matching on matricule
    
    -- Metadata
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    CHECK (sexe IN ('M', 'F', 'Autre'))
);

-- Table: Formation
CREATE TABLE formation (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    programme_id INTEGER NOT NULL,
    annee_univ_id INTEGER NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (programme_id) REFERENCES programme(id) ON DELETE RESTRICT,
    FOREIGN KEY (annee_univ_id) REFERENCES annee_universitaire(id) ON DELETE RESTRICT,
    UNIQUE(programme_id, annee_univ_id)
);

-- Table: Groupe
CREATE TABLE groupe (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    code TEXT NOT NULL,
    formation_id INTEGER NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (formation_id) REFERENCES formation(id) ON DELETE CASCADE,
    UNIQUE(code, formation_id)
);

-- Table: Matiere
CREATE TABLE matiere (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    code TEXT NOT NULL UNIQUE,
    title TEXT NOT NULL,
    coefficient REAL NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CHECK (coefficient &gt; 0)
);

-- Table: PeriodeProgramme
CREATE TABLE periode_programme (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    libelle TEXT NOT NULL,
    ordre INTEGER NOT NULL,
    programme_id INTEGER NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (programme_id) REFERENCES programme(id) ON DELETE CASCADE,
    UNIQUE(libelle, programme_id)
);

-- Table: Module
CREATE TABLE module (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    matiere_id INTEGER NOT NULL,
    periode_id INTEGER NOT NULL,
    coefficient REAL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (matiere_id) REFERENCES matiere(id) ON DELETE RESTRICT,
    FOREIGN KEY (periode_id) REFERENCES periode_programme(id) ON DELETE CASCADE,
    UNIQUE(matiere_id, periode_id)
);

-- =====================================================
-- INSCRIPTION TABLES
-- =====================================================

-- Table: Inscription
CREATE TABLE inscription (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    etudiant_id INTEGER NOT NULL,
    formation_id INTEGER NOT NULL,
    groupe_id INTEGER NOT NULL,
    moy REAL,
    rachat INTEGER DEFAULT 0,
    rattrapage INTEGER DEFAULT 0,
    rang INTEGER,
    decisionJury TEXT,
    observation TEXT,
    date_inscription TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (etudiant_id) REFERENCES etudiant(id) ON DELETE CASCADE,
    FOREIGN KEY (formation_id) REFERENCES formation(id) ON DELETE RESTRICT,
    FOREIGN KEY (groupe_id) REFERENCES groupe(id) ON DELETE RESTRICT,
    UNIQUE(etudiant_id, formation_id)
);

-- Table: InscriptionPeriode
CREATE TABLE inscription_periode (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    inscription_id INTEGER NOT NULL,
    periodepgm_id INTEGER NOT NULL,
    groupe_id INTEGER NOT NULL,
    moy REAL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (inscription_id) REFERENCES inscription(id) ON DELETE CASCADE,
    FOREIGN KEY (periodepgm_id) REFERENCES periode_programme(id) ON DELETE RESTRICT,
    FOREIGN KEY (groupe_id) REFERENCES groupe(id) ON DELETE RESTRICT,
    UNIQUE(inscription_id, periodepgm_id)
);

-- Table: Resultat
CREATE TABLE resultat (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    inscriptionPer_id INTEGER NOT NULL,
    module_id INTEGER NOT NULL,
    moy REAL,
    note_cc REAL,
    note_exam REAL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (inscriptionPer_id) REFERENCES inscription_periode(id) ON DELETE CASCADE,
    FOREIGN KEY (module_id) REFERENCES module(id) ON DELETE RESTRICT,
    UNIQUE(inscriptionPer_id, module_id),
    CHECK (moy &gt;= 0 AND moy &lt;= 20),
    CHECK (note_cc &gt;= 0 AND note_cc &lt;= 20),
    CHECK (note_exam &gt;= 0 AND note_exam &lt;= 20)
);

-- =====================================================
-- SEARCH OPTIMIZATION TABLES
-- =====================================================

-- Table: RechercheNameLog (search history)
CREATE TABLE recherche_name_log (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    etudiant_id INTEGER,
    terme_recherche TEXT NOT NULL,
    terme_normalise TEXT,
    type_recherche TEXT,
    resultats_trouves INTEGER DEFAULT 0,
    correction_utilisateur INTEGER DEFAULT 0,
    date_recherche TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (etudiant_id) REFERENCES etudiant(id) ON DELETE SET NULL
);

-- Table: VariationNom (learned name variations)
CREATE TABLE variation_nom (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    etudiant_id INTEGER NOT NULL,
    nom_canonique TEXT NOT NULL,
    variation TEXT NOT NULL,
    frequence INTEGER DEFAULT 1,
    derniere_utilisation TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (etudiant_id) REFERENCES etudiant(id) ON DELETE CASCADE,
    UNIQUE(etudiant_id, variation)
);

-- =====================================================
-- INDEXES FOR PERFORMANCE (INCLUDING MATRICULE)
-- =====================================================

-- Primary indexes for exact matching
CREATE INDEX idx_etudiant_nom ON etudiant(nom);
CREATE INDEX idx_etudiant_prenom ON etudiant(prenom);
CREATE INDEX idx_etudiant_nom_prenom ON etudiant(nom, prenom);

-- ========== MATRICULE INDEXES ==========
-- Primary unique index (already created by UNIQUE constraint)
-- But we add additional indexes for different search patterns:

-- 1. Exact match on matricule (uses the UNIQUE constraint automatically)
-- 2. Prefix search on matricule (for autocomplete)
CREATE INDEX idx_etudiant_matricule_prefix ON etudiant(matricule);

-- 3. Case-insensitive matricule search
CREATE INDEX idx_etudiant_matricule_lower ON etudiant(LOWER(matricule));

-- 4. Normalized matricule (removing special characters)
CREATE INDEX idx_etudiant_matricule_normalise ON etudiant(matricule_normalise);

-- 5. Partial matricule (last 4 digits - common for searches)
CREATE INDEX idx_etudiant_matricule_suffix ON etudiant(SUBSTR(matricule, -4));

-- 6. For numeric-only matricule searches
CREATE INDEX idx_etudiant_matricule_numeric ON etudiant(
    CAST(
        CASE 
            WHEN matricule GLOB '[0-9]*' THEN matricule 
            ELSE NULL 
        END AS INTEGER
    )
) WHERE matricule GLOB '[0-9]*';

-- 7. Composite index with name for combined searches
CREATE INDEX idx_etudiant_matricule_nom ON etudiant(matricule, nom);

-- 8. For matricule + prenom searches
CREATE INDEX idx_etudiant_matricule_prenom ON etudiant(matricule, prenom);

-- =====================================================

-- Soundex indexes for phonetic matching
CREATE INDEX idx_etudiant_nom_soundex ON etudiant(nom_soundex);
CREATE INDEX idx_etudiant_prenom_soundex ON etudiant(prenom_soundex);

-- Metaphone indexes
CREATE INDEX idx_etudiant_nom_metaphone ON etudiant(nom_metaphone);
CREATE INDEX idx_etudiant_prenom_metaphone ON etudiant(prenom_metaphone);

-- Foreign key indexes
CREATE INDEX idx_formation_programme ON formation(programme_id);
CREATE INDEX idx_formation_annee ON formation(annee_univ_id);
CREATE INDEX idx_groupe_formation ON groupe(formation_id);
CREATE INDEX idx_module_matiere ON module(matiere_id);
CREATE INDEX idx_module_periode ON module(periode_id);
CREATE INDEX idx_periode_programme ON periode_programme(programme_id);

-- Inscription indexes
CREATE INDEX idx_inscription_etudiant ON inscription(etudiant_id);
CREATE INDEX idx_inscription_formation ON inscription(formation_id);
CREATE INDEX idx_inscription_groupe ON inscription(groupe_id);
CREATE INDEX idx_inscription_periode_inscription ON inscription_periode(inscription_id);
CREATE INDEX idx_inscription_periode_periodepgm ON inscription_periode(periodepgm_id);
CREATE INDEX idx_inscription_periode_groupe ON inscription_periode(groupe_id);

-- Resultat indexes
CREATE INDEX idx_resultat_inscriptionper ON resultat(inscriptionPer_id);
CREATE INDEX idx_resultat_module ON resultat(module_id);

-- Search log indexes
CREATE INDEX idx_recherche_log_etudiant ON recherche_name_log(etudiant_id);
CREATE INDEX idx_recherche_log_date ON recherche_name_log(date_recherche);
CREATE INDEX idx_recherche_log_terme ON recherche_name_log(terme_normalise);

-- Variation indexes
CREATE INDEX idx_variation_etudiant ON variation_nom(etudiant_id);
CREATE INDEX idx_variation_variation ON variation_nom(variation);
CREATE INDEX idx_variation_frequence ON variation_nom(frequence DESC);

-- =====================================================
-- SIMPLE TRIGGERS
-- =====================================================

-- Trigger to update timestamps on etudiant
CREATE TRIGGER update_etudiant_timestamp 
AFTER UPDATE ON etudiant
BEGIN
    UPDATE etudiant SET updated_at = CURRENT_TIMESTAMP WHERE id = NEW.id;
END;

-- Trigger to update timestamps on inscription
CREATE TRIGGER update_inscription_timestamp 
AFTER UPDATE ON inscription
BEGIN
    UPDATE inscription SET updated_at = CURRENT_TIMESTAMP WHERE id = NEW.id;
END;

-- Trigger to populate matricule_normalise on insert
CREATE TRIGGER populate_matricule_normalise
AFTER INSERT ON etudiant
BEGIN
    UPDATE etudiant 
    SET matricule_normalise = 
        LOWER(
            REPLACE(
                REPLACE(
                    REPLACE(NEW.matricule, '-', ''),
                    '_', ''
                ),
                ' ', ''
            )
        )
    WHERE id = NEW.id;
END;

-- Trigger to update variation frequency
CREATE TRIGGER update_variation_frequency 
AFTER INSERT ON recherche_name_log
WHEN NEW.correction_utilisateur = 1 AND NEW.etudiant_id IS NOT NULL
BEGIN
    INSERT OR IGNORE INTO variation_nom 
        (etudiant_id, nom_canonique, variation, frequence, derniere_utilisation)
    VALUES (
        NEW.etudiant_id,
        (SELECT nom || ' ' || prenom FROM etudiant WHERE id = NEW.etudiant_id),
        NEW.terme_recherche,
        1,
        CURRENT_TIMESTAMP
    );
    
    UPDATE variation_nom 
    SET frequence = frequence + 1,
        derniere_utilisation = CURRENT_TIMESTAMP
    WHERE etudiant_id = NEW.etudiant_id AND variation = NEW.terme_recherche;
END;

-- =====================================================
-- FULL-TEXT SEARCH (SQLite FTS5)
-- =====================================================

-- Create FTS5 virtual table for full-text search
CREATE VIRTUAL TABLE IF NOT EXISTS etudiant_fts USING fts5(
    etudiant_id UNINDEXED,
    nom,
    prenom,
    matricule,
    content=''
);

-- Triggers to keep FTS index updated
CREATE TRIGGER IF NOT EXISTS etudiant_fts_insert 
AFTER INSERT ON etudiant
BEGIN
    INSERT INTO etudiant_fts(etudiant_id, nom, prenom, matricule)
    VALUES (new.id, new.nom, new.prenom, new.matricule);
END;

CREATE TRIGGER IF NOT EXISTS etudiant_fts_update 
AFTER UPDATE ON etudiant
BEGIN
    DELETE FROM etudiant_fts WHERE etudiant_id = old.id;
    INSERT INTO etudiant_fts(etudiant_id, nom, prenom, matricule)
    VALUES (new.id, new.nom, new.prenom, new.matricule);
END;

CREATE TRIGGER IF NOT EXISTS etudiant_fts_delete 
AFTER DELETE ON etudiant
BEGIN
    DELETE FROM etudiant_fts WHERE etudiant_id = old.id;
END;

-- =====================================================
-- VIEWS
-- =====================================================

-- View: Student summary
CREATE VIEW IF NOT EXISTS vw_etudiant_summary AS
SELECT 
    id,
    nom,
    prenom,
    nom || ' ' || prenom AS full_name,
    matricule,
    date_naissance,
    sexe
FROM etudiant;

-- View: Current inscriptions
CREATE VIEW IF NOT EXISTS vw_inscriptions_actuelles AS
SELECT 
    i.id AS inscription_id,
    e.id AS etudiant_id,
    e.nom,
    e.prenom,
    e.matricule,
    f.id AS formation_id,
    p.code AS programme_code,
    p.titre AS programme_titre,
    a.annee AS annee_universitaire,
    g.code AS groupe,
    i.moy AS moyenne_generale,
    i.decisionJury,
    i.rang
FROM inscription i
JOIN etudiant e ON i.etudiant_id = e.id
JOIN formation f ON i.formation_id = f.id
JOIN programme p ON f.programme_id = p.id
JOIN annee_universitaire a ON f.annee_univ_id = a.id
JOIN groupe g ON i.groupe_id = g.id
WHERE a.date_fin &gt;= DATE('now');

-- View: Student grades
CREATE VIEW IF NOT EXISTS vw_resultats_etudiant AS
SELECT 
    e.id AS etudiant_id,
    e.nom,
    e.prenom,
    a.annee AS annee_univ,
    pp.libelle AS periode,
    m.code AS matiere_code,
    m.title AS matiere_title,
    r.moy AS note,
    r.note_cc,
    r.note_exam
FROM etudiant e
JOIN inscription i ON e.id = i.etudiant_id
JOIN formation f ON i.formation_id = f.id
JOIN annee_universitaire a ON f.annee_univ_id = a.id
JOIN inscription_periode ip ON i.id = ip.inscription_id
JOIN periode_programme pp ON ip.periodepgm_id = pp.id
JOIN resultat r ON ip.id = r.inscriptionPer_id
JOIN module mod ON r.module_id = mod.id
JOIN matiere m ON mod.matiere_id = m.id;

-- View: Search analytics
CREATE VIEW IF NOT EXISTS vw_search_analytics AS
SELECT 
    type_recherche,
    COUNT(*) AS total_searches,
    AVG(resultats_trouves) AS avg_results,
    SUM(CASE WHEN correction_utilisateur THEN 1 ELSE 0 END) AS corrections,
    ROUND(100.0 * SUM(CASE WHEN correction_utilisateur THEN 1 ELSE 0 END) / COUNT(*), 2) AS correction_rate,
    DATE(date_recherche) AS search_date
FROM recherche_name_log
GROUP BY type_recherche, DATE(date_recherche);

-- =====================================================
</sql><current_tab id="0"/></tab_sql></sqlb_project>
