-- =====================================================
-- USEFUL SEARCH QUERIES (commented out - for reference)
-- =====================================================

/*
-- Search by name prefix (fast, uses index)
SELECT * FROM etudiant 
WHERE nom LIKE 'Bou%' OR prenom LIKE 'Bou%' 
ORDER BY nom, prenom 
LIMIT 20;

-- Search with Soundex (phonetic)
SELECT * FROM etudiant 
WHERE nom_soundex = (
    SELECT nom_soundex FROM etudiant WHERE nom = 'Boubaker' LIMIT 1
);

-- Search using learned variations
SELECT e.*, v.frequence 
FROM etudiant e
JOIN variation_nom v ON e.id = v.etudiant_id
WHERE v.variation = 'boukaker'
ORDER BY v.frequence DESC;

-- Full-text search
SELECT e.* 
FROM etudiant e
JOIN etudiant_fts f ON e.id = f.etudiant_id
WHERE etudiant_fts MATCH 'boukaker';
*/</sql><current_tab id="0"/></tab_sql></sqlb_project>
